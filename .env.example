# =============================================================================
# Wirbooks — TEK ortam dosyası şablonu
# =============================================================================
# Üretim: bu dosyayı /root/data/.env olarak kopyalayın (chmod 600).
# Tüm servisler sırayla şunu dener:
#   1) ENV_PATH ortam değişkeni (dosya yolu)
#   2) /root/data/.env (varsa)
#   3) Yerel geliştirme: ilgili proje klasöründeki .env
#       (backend/.env, web/.env, admin-panel/.env)
# =============================================================================

# --- Backend (Express API) ---
PORT=3001
NODE_ENV=development

DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=wirbooks

# İstemciler X-API-Key ile (isteğe bağlı)
API_KEY=

# Admin API uçları (X-Admin-Key) — admin panel ENV ile aynı olmalı
ADMIN_API_KEY=

# Yükleme
UPLOAD_BASE_URL=https://api.wirbooks.com.tr
UPLOAD_MAX_SIZE_MB=50

# Veritabanı atlamak için (nadiren)
# SKIP_DB_INIT=true

# --- Next.js web (build / runtime — NEXT_PUBLIC_* build anında gömülür) ---
NEXT_PUBLIC_API_URL=https://api.wirbooks.com.tr/api
NEXT_PUBLIC_API_KEY=

# --- Admin panel (Express, admin.wirbooks.com.tr) ---
# API kökü: sonunda /api OLMAMALI
BACKEND_URL=https://api.wirbooks.com.tr
# Backend PORT ile karışmaması için ayrı anahtar (varsayılan: 3050)
ADMIN_PANEL_PORT=3050

SESSION_SECRET=buraya-uzun-rastgele-bir-string

ADMIN_USERNAME=admin
ADMIN_PASSWORD=guclu-bir-sifre-degistir

# Üretimde HTTPS çerez: TRUST_SECURE_COOKIE=true
# TRUST_SECURE_COOKIE=true

# =============================================================================
# Mobil (Expo) — bu dosyayı doğrudan okumaz; app.json / eas.json veya .env.local
# =============================================================================
# EXPO_PUBLIC_API_URL=https://api.wirbooks.com.tr/api
# EXPO_PUBLIC_API_KEY=

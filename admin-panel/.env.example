# =============================================================================
# Admin panel (bu klasördeki Express sunucusu — npm run dev / npm start)
# =============================================================================
# Uzak API kökü: sonunda /api OLMAMALI (proxy /api/admin/... ekler)
BACKEND_URL=https://api.wirbooks.com.tr

PORT=3051

# Oturum çerezi imzası (üretimde güçlü rastgele değer)
SESSION_SECRET=buraya-uzun-rastgele-bir-string

# Panel girişi (sadece bu sunucu okur; tarayıcıya yazılmaz)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=guclu-bir-sifre-degistir

# Backend admin API anahtarı (X-Admin-Key) — backend .env ADMIN_API_KEY ile aynı olmalı
ADMIN_API_KEY=backenddeki-admin-api-key-ile-ayni

# =============================================================================
# İsteğe bağlı — başka projeler (Expo, Next vb.) için referans
# Admin panel bunları OKUMAZ; kopyalarken sadece ihtiyacın olan bloğu kullan.
# =============================================================================
# Genel istemci API anahtarı (X-API-Key) — backend .env ile aynı olmalı
# API_KEY=

# Next / web build
# NEXT_PUBLIC_API_URL=https://api.wirbooks.com.tr/api
# NEXT_PUBLIC_API_KEY=

# Upload tam URL kökü (çoğu kurulumda API host ile aynı)
# UPLOAD_BASE_URL=https://api.wirbooks.com.tr
# UPLOAD_MAX_SIZE_MB=50

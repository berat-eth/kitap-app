# --- Uzak backend (önerilen) ---
# Sadece köken: şema + host, sonunda /api OLMAMALI.
# İstekler panel sunucusundan şu adrese gider: BACKEND_URL + /api/admin/...
BACKEND_URL=https://api.wirbooks.com.tr

# Panel dinleme portu
PORT=3051

# Oturum çerezi imzası (üretimde güçlü rastgele değer)
SESSION_SECRET=buraya-uzun-rastgele-bir-string

# Not: Admin API anahtarı .env'de tutulmaz; giriş ekranında girilir (sunucu oturumunda saklanır).

# Yerel geliştirme: bu dosyayı .env yapın VEYA repo kökündeki tek dosyayı kullanın.
#
# Üretimde tüm servisler şunu okur (sırayla):
#   ENV_PATH  →  /root/data/.env  →  bu klasördeki .env
#
# Tam şablon: repo kökündeki /.env.example

BACKEND_URL=http://127.0.0.1:3001
ADMIN_PANEL_PORT=3051
SESSION_SECRET=yerel-gelistirme-icin-rastgele-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=yerel-sifre
ADMIN_API_KEY=backend-ADMIN_API_KEY-ile-aynı
